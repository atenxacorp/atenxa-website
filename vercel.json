{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    { "src": "/propic.png", "dest": "/public/propic.png" },
    { "src": "/pricing.php", "dest": "/api/pricing.php" },
    { "src": "/public/(.*)", "dest": "/public/$1" },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/robots.txt", "dest": "/public/robots.txt" },
    { "src": "/llms.txt", "dest": "/public/llms.txt" },
    { "src": "/sitemap.xml", "dest": "/public/sitemap.xml" },
    { "src": "/submit.php", "dest": "/api/submit.php" },
    { "src": "/upload.php", "dest": "/api/upload.php" },
    { "src": "/privacy.php", "dest": "/api/privacy.php" },
    { "src": "/terms.php", "dest": "/api/terms.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
